    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^6.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.40.2",
    "wrangler": "^4.100.0"
  }
}
